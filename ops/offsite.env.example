# NOC off-site backup target. Copy this to ops/offsite.env ON THE SERVER (gitignored)
# and fill in YOUR backup server's details:
#
#     cp /root/noc/ops/offsite.env.example /root/noc/ops/offsite.env
#     nano /root/noc/ops/offsite.env
#
# The VPS pushes with the key /root/.ssh/noc_backup (already generated). Put its PUBLIC
# half — `cat /root/.ssh/noc_backup.pub` — into the backup user's authorized_keys on the
# remote. Then:  bash /root/noc/ops/offsite-backup.sh --test
# Full steps: ops/OFFSITE.md

OFFSITE_HOST=backup.example.com        # your backup server hostname or IP
OFFSITE_USER=nocbackup                 # ssh user on the backup server
OFFSITE_PORT=22                        # ssh port (change if non-standard)
OFFSITE_PATH=/home/nocbackup/noc       # directory on the backup server to receive the copy
OFFSITE_SSH_KEY=/root/.ssh/noc_backup  # VPS private key (leave as-is unless you use another)

# OFFSITE_DELETE=1   # 1 (default): remote MIRRORS the local 14-day window — bounded, predictable.
#                    # 0: remote KEEPS every backup ever pushed — more history, but grows over time.
