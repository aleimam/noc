# Optional overrides for ops/backup.sh. Copy to ops/backup.env ON THE SERVER
# (it is gitignored) ONLY if the automatic DATABASE_URL parsing doesn't work
# for you - e.g. a DB password with unusual characters. Most setups need none
# of this; backup.sh reads /root/noc/.env automatically.

# RETAIN_DAYS=14            # keep this many days of backups
# BACKUP_ROOT=/root/backups # where backups are written

# Explicit DB credentials (bypass DATABASE_URL parsing entirely):
# DB_NAME=noc
# DB_USER=noc_user
# DB_PASS=the_real_password
# DB_HOST=127.0.0.1
# DB_PORT=3306
