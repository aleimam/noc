// NOC Platform — Prisma schema (MySQL).
// Foundation models: users (3 types), RBAC, Auth.js (DB sessions), OTP,
// customer preferences, and polymorphic media attachments.
// Business-module models (sheets, lands, districts, owners…) are added later.

generator client {
  provider   = "prisma-client-js"
  // Native (.node) engine has no Windows/ARM64 build; the binary engine runs the
  // x64 query-engine.exe as a child process (works under Win11 ARM emulation,
  // and natively on the Linux server).
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserType {
  STAFF
  CUSTOMER
  PARTNER
}

enum PartnerKind {
  BROKER
  COMPANY
}

enum PermAction {
  VIEW
  CREATE
  UPDATE
  DELETE
  MANAGE
}

enum Appearance {
  SYSTEM
  LIGHT
  DARK
}

enum Locale {
  AR
  EN
}

model User {
  id              String    @id @default(cuid())
  type            UserType
  email           String?   @unique // staff
  passwordHash    String? // staff
  phone           String?   @unique // customer
  phoneVerifiedAt DateTime?
  name            String?
  partnerKind     PartnerKind? // for PARTNER users: broker vs company
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  roles       UserRole[]
  directPerms UserPermission[]
  preference  CustomerPreference?
  sessions    Session[]
  accounts    Account[]
  uploads     Attachment[]        @relation("Uploader")
  listings        Listing[]       @relation("ListingSeller")
  listingsCreated Listing[]       @relation("ListingCreator")
  sheetUploads    RationingSheet[]   @relation("SheetUploader")
  scanUploads     RationingScan[]    @relation("ScanUploader")
  sheetBatches    SheetImportBatch[]
  inquiries       InquiryRequest[]
  sheetSearches   SheetSearchLog[]
  landsCreated    Land[]             @relation("LandCreator")
  geoUpdates      GeoUpdate[]        @relation("GeoUpdateAuthor")
  landFollows     LandFollow[]
  rationingFollows RationingFollow[]
  contactRequests ContactRequest[]
  wishlists       WishlistList[]
  landOffers      LandOffer[]

  @@index([type])
}

// ───────────────────────────── RBAC ─────────────────────────────

model Role {
  id          String           @id @default(cuid())
  key         String           @unique // SUPER_ADMIN, EDITOR, SUPPORT…
  name        String
  description String?
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id      String           @id @default(cuid())
  section String // 'listings', 'customers', …
  action  PermAction
  roles   RolePermission[]
  users   UserPermission[]

  @@unique([section, action])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model UserPermission {
  userId       String
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
}

// ─────────────────────── Auth.js (DB sessions) ───────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ───────────────────────────── OTP ─────────────────────────────

model OtpCode {
  id         String    @id @default(cuid())
  phone      String
  codeHash   String // never store the plaintext code
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, consumedAt])
}

// ─────────────────────────── Preferences ───────────────────────────

model CustomerPreference {
  userId     String     @id
  locale     Locale     @default(AR)
  appearance Appearance @default(SYSTEM)
  updatedAt  DateTime   @updatedAt
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ───────────────────────── Media (polymorphic) ─────────────────────────

model Attachment {
  id           String   @id @default(cuid())
  filename     String // stored uuid filename
  originalName String
  path         String // public URL, e.g. /uploads/2026/06/uuid.webp
  mime         String
  size         Int // bytes (<= 32MB enforced in app)
  width        Int?
  height       Int?
  ownerType    String? // 'Listing', 'HomepageBlock'… (null = draft)
  ownerId      String?
  attributeId  String? // set when this file belongs to a specific PHOTOS/DOCUMENTS attribute (null = main listing gallery)
  uploaderId   String?
  uploader     User?    @relation("Uploader", fields: [uploaderId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([ownerType, ownerId])
  @@index([uploaderId])
}

// ─────────────────────────── Marketplace (EAV) ───────────────────────────

enum ListingStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
  SOLD
  ARCHIVED
}

enum AttrType {
  TEXT
  TEXTAREA
  NUMBER
  BOOLEAN
  SELECT
  MULTI_SELECT
  DATE // month + year
  PHOTOS // image attachments (shown publicly)
  DOCUMENTS // file attachments (kept internal / admin-only)
}

/// Classifier dimension — Type, Purpose, Condition. Fixed set; options are admin-editable.
model Classifier {
  id        String   @id @default(cuid())
  key       String   @unique // 'type' | 'purpose' | 'condition'
  nameAr    String
  nameEn    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  options ClassifierOption[]

  @@index([order])
}

/// An option within a classifier (Type: Apartment; Purpose: Residential; Condition: Finished…).
model ClassifierOption {
  id           String   @id @default(cuid())
  classifierId String
  key          String
  nameAr       String
  nameEn       String
  order        Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  classifier        Classifier            @relation(fields: [classifierId], references: [id], onDelete: Cascade)
  attrLinks         AttributeClassifier[]
  typeListings      Listing[]             @relation("ListingType")
  purposeListings   Listing[]             @relation("ListingPurpose")
  conditionListings Listing[]             @relation("ListingCondition")

  @@unique([classifierId, key])
  @@index([classifierId, order])
}

/// Attribute applicability: which classifier OPTIONS an attribute applies to. For each
/// classifier the attribute constrains, a listing's selected option must be linked here;
/// no link for a classifier means the attribute applies to ALL of that classifier's options.
model AttributeClassifier {
  id          String @id @default(cuid())
  attributeId String
  optionId    String

  attribute Attribute        @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  option    ClassifierOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([attributeId, optionId])
  @@index([optionId])
}

/// Legacy real-estate type — superseded by the Type classifier. Kept dormant for old listings.
model PropertyType {
  id        String   @id @default(cuid())
  key       String   @unique
  nameAr    String
  nameEn    String
  icon      String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attributes PropertyTypeAttribute[]
  listings   Listing[]

  @@index([isActive, order])
}

/// A group of attributes (الموقع / المواصفات / المرافق…). Bilingual.
model AttributeSection {
  id        String   @id @default(cuid())
  key       String   @unique
  nameAr    String
  nameEn    String
  icon      String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attributes Attribute[]

  @@index([isActive, order])
}

/// A single configurable characteristic. Bilingual label + optional unit.
model Attribute {
  id         String   @id @default(cuid())
  key        String   @unique
  sectionId  String
  labelAr    String
  labelEn    String
  type       AttrType
  unit       String?
  helpAr     String?
  helpEn     String?
  filterable Boolean  @default(false)
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  section        AttributeSection        @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  options        AttributeOption[]
  typeLinks      PropertyTypeAttribute[] // legacy
  classifierLinks AttributeClassifier[]
  values         ListingValue[]

  @@index([sectionId, order])
  @@index([filterable])
}

/// Allowed choice for SELECT / MULTI_SELECT. Bilingual.
model AttributeOption {
  id          String  @id @default(cuid())
  attributeId String
  key         String
  labelAr     String
  labelEn     String
  order       Int     @default(0)
  isActive    Boolean @default(true)

  attribute Attribute      @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  values    ListingValue[]

  @@unique([attributeId, key])
  @@index([attributeId, order])
}

/// type ↔ attribute mapping (which attributes apply to which property types).
model PropertyTypeAttribute {
  id             String  @id @default(cuid())
  propertyTypeId String
  attributeId    String
  required       Boolean @default(false)
  order          Int     @default(0)

  propertyType PropertyType @relation(fields: [propertyTypeId], references: [id], onDelete: Cascade)
  attribute    Attribute    @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([propertyTypeId, attributeId])
  @@index([attributeId])
}

/// A seller's offer. Free text is Arabic; structured values live in ListingValue.
model Listing {
  id              String        @id @default(cuid())
  sellerId        String
  createdById     String?
  propertyTypeId  String? // legacy (superseded by typeOptionId)
  typeOptionId      String?
  purposeOptionId   String?
  conditionOptionId String?
  title           String
  description     String?       @db.Text
  price           Decimal?      @db.Decimal(14, 2)
  soldPrice       Decimal?      @db.Decimal(14, 2) // set by staff when marked SOLD; optionally shown publicly
  adNumber        String?       @unique // public ad reference YYMM+owner(2)+seq, frozen at publish
  featured        Boolean       @default(false) // promoted on the storefront (manual)
  priceNote       String?
  contactPhone    String
  contactWhatsapp Boolean       @default(true)
  showOnBrokerage Boolean       @default(false)
  ownerId         String?
  ownerName       String?
  ownerType       OwnerType?
  neighborhoodId  String? // optional location link into the geographic database (Module 2)
  status          ListingStatus @default(PENDING)
  rejectionReason String?
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  seller          User              @relation("ListingSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  createdBy       User?             @relation("ListingCreator", fields: [createdById], references: [id], onDelete: SetNull)
  contactRequests ContactRequest[]
  wishlistItems   WishlistItem[]
  propertyType    PropertyType?     @relation(fields: [propertyTypeId], references: [id], onDelete: SetNull)
  typeOption      ClassifierOption? @relation("ListingType", fields: [typeOptionId], references: [id], onDelete: SetNull)
  purposeOption   ClassifierOption? @relation("ListingPurpose", fields: [purposeOptionId], references: [id], onDelete: SetNull)
  conditionOption ClassifierOption? @relation("ListingCondition", fields: [conditionOptionId], references: [id], onDelete: SetNull)
  owner        Owner?         @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  neighborhood Neighborhood?  @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  sourceLand   Land?          @relation("LandListing")
  values       ListingValue[]

  @@index([status, propertyTypeId])
  @@index([sellerId, status])
  @@index([showOnBrokerage, status])
  @@index([neighborhoodId])
  @@index([publishedAt])
}

/// EAV value store. MULTI_SELECT = one row per chosen option.
model ListingValue {
  id          String   @id @default(cuid())
  listingId   String
  attributeId String
  text        String?  @db.Text
  number      Decimal? @db.Decimal(14, 2)
  bool        Boolean?
  optionId    String?

  listing   Listing          @relation(fields: [listingId], references: [id], onDelete: Cascade)
  attribute Attribute        @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  option    AttributeOption? @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([listingId, attributeId, optionId])
  @@index([listingId])
  @@index([attributeId, optionId])
  @@index([attributeId, number])
}

enum OwnerType {
  OWNER
  COMPANY
  BROKER
  US
}

/// Reusable commercial owners/contacts list (staff-managed) — used for our inventory.
model Owner {
  id             String    @id @default(cuid())
  name           String
  ownerNo        Int? // admin-allocated 2-digit code for ad numbers (our lands 00-09); unique
  type           OwnerType @default(OWNER)
  phone1         String?
  phone1Whatsapp Boolean   @default(false)
  phone2         String?
  phone2Whatsapp Boolean   @default(false)
  details        String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  listings Listing[]
  lands    Land[]

  @@unique([ownerNo])
  @@index([type])
}

enum LeadStatus {
  NEW
  CONTACTED
  NEGOTIATING
  SOLD
  LOST
}

/// A buyer lead from the storefront ("أريد شراءها" / contact). Saved for staff follow-up
/// in the New Obour backend; also opens WhatsApp to the central number.
model ContactRequest {
  id        String     @id @default(cuid())
  listingId String?
  userId    String? // set when a logged-in customer
  name      String?
  phone     String?
  message   String?    @db.Text
  status    LeadStatus @default(NEW)
  note      String?    @db.Text // internal staff note
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  listing Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([listingId])
  @@index([createdAt])
}

enum LandOfferMode {
  SHEET // كشف — rationing-sheet land (identified by owner name in the ledger)
  ALLOCATED // تخصيص — already-specified land (plot/block in the geo hierarchy)
}

enum LandOfferStatus {
  NEW
  REVIEWING
  ACCEPTED
  REJECTED
}

/// A "sell your land" submission from the alsawarey storefront. Staff review it in the
/// New Obour backend (never auto-published). Photos (papers/maps) attach as internal
/// Attachments (ownerType = 'LandOffer'); never shown publicly.
model LandOffer {
  id             String          @id @default(cuid())
  mode           LandOfferMode
  ownerName      String
  phone1         String
  phone2         String?
  area           Decimal?        @db.Decimal(10, 2)
  originalArea   Decimal?        @db.Decimal(10, 2) // ALLOCATED
  cityId         String? // SHEET → RationingCity
  districtId     String? // ALLOCATED → geo District (الحي)
  neighborhoodId String? // ALLOCATED → geo Neighborhood (المجاورة)
  blockNo        String?
  plotNo         String?
  requiredPrice  Decimal?        @db.Decimal(14, 2)
  details        String?         @db.Text
  status         LandOfferStatus @default(NEW)
  note           String?         @db.Text // internal staff note
  userId         String? // set when submitted by a logged-in customer
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  city         RationingCity? @relation(fields: [cityId], references: [id], onDelete: SetNull)
  district     District?      @relation(fields: [districtId], references: [id], onDelete: SetNull)
  neighborhood Neighborhood?  @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  user         User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}

/// A named wishlist/collection on the storefront. Owned by a logged-in customer
/// (userId) or an anonymous visitor via a cookie id. ownerKey = 'u:<userId>' | 'a:<anonId>'.
model WishlistList {
  id        String   @id @default(cuid())
  ownerKey  String
  userId    String?
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WishlistItem[]

  @@index([ownerKey])
  @@index([userId])
}

/// A land saved into a wishlist.
model WishlistItem {
  id        String   @id @default(cuid())
  listId    String
  listingId String
  createdAt DateTime @default(now())

  list    WishlistList @relation(fields: [listId], references: [id], onDelete: Cascade)
  listing Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listId, listingId])
  @@index([listingId])
}

/// Simple key/value app settings (e.g. the central ALSWARY contact number).
model Setting {
  key   String @id
  value String @db.Text
}

/// Admin-managed static page (about, contact, privacy, terms…). Per-brand, bilingual,
/// rich HTML body. Listed in the site footer when published.
model Page {
  id          String   @id @default(cuid())
  brand       String // 'newobour' | 'alsawarey'
  slug        String
  titleAr     String
  titleEn     String?
  bodyAr      String   @db.Text
  bodyEn      String?  @db.Text
  published   Boolean  @default(false)
  footerOrder Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([brand, slug])
  @@index([brand, published, footerOrder])
}

// ─────────────────── Module 1: Rationing Sheets (كشوف التقنين) ───────────────────

enum InquiryKind {
  FOUND_FOLLOW // customer found their land → wants updates about it
  NOT_FOUND_WATCH // customer didn't find it → notify when it appears
}

enum InquiryStatus {
  OPEN
  MATCHED
  CLOSED
}

/// An admin-editable city / zone list for rationing sheets (e.g. القادسية، الكيلو 48).
/// Deliberately separate from the Module-2 geo District/Neighborhood hierarchy.
model RationingCity {
  id         String   @id @default(cuid())
  name       String   @unique // Arabic name as entered
  nameEn     String?
  normalized String   @unique // normalized form for soft matching / import upsert
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sheets  RationingSheet[]
  follows RationingFollow[]
  offers  LandOffer[]

  @@index([isActive, order])
}

/// One applicant row of a government rationing sheet (كشف تقنين). Staff import these from Excel.
/// Applicant-centric: a plot's original owner is split among many applicants (beneficiaries).
model RationingSheet {
  id            String  @id @default(cuid())
  applicantNo   Int? // "Applicant No" within the source file
  applicantName String // raw applicant cell, kept exactly as imported (may hold several people)
  plotNo        String // "Plot No" (قطعة)
  blockNo       String // "Block No" (مربع / مجموعة)
  plotFullRef   String? // "Plot Full Reference" — merge of plot + block
  cityId        String?
  originalOwner String? // the original (pre-split) land owner

  attendanceDay  String? // weekday label (الأحد…)
  attendanceDate DateTime?
  listDate       DateTime?

  declarationRequired Boolean @default(false) // "Declaration Required" (Yes/No)
  declarationDetails  String? @db.Text

  // Internal-only — never shown to visitors:
  remarks    String? @db.Text // e.g. "OCR needs verification"
  sourceFile String? // scanned page filename; links to a scan in phase 2

  // Soft-search helpers (normalized: de-diacritized, unified letters, Latin digits):
  ownerNorm String?
  plotNorm  String?
  blockNorm String?
  dedupeKey String // normalized applicantName|plotNo|blockNo — duplicate detection

  // OCR-verification workflow:
  needsReview Boolean   @default(false) // seeded from a non-empty Remarks on import
  reviewedAt  DateTime?

  batchId      String?
  uploadedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  city       RationingCity?    @relation(fields: [cityId], references: [id], onDelete: SetNull)
  batch      SheetImportBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  uploadedBy User?             @relation("SheetUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  names      RationingName[]
  inquiries  InquiryRequest[]
  follows    RationingFollow[] @relation("FollowSheet")

  @@index([plotNo, blockNo])
  @@index([dedupeKey])
  @@index([ownerNorm])
  @@index([plotNorm])
  @@index([blockNorm])
  @@index([cityId])
  @@index([batchId])
  @@index([needsReview])
}

/// A searchable person name derived from a RationingSheet.applicantName — the raw cell
/// is expanded into one row per real person (multi-owner names share a surname).
model RationingName {
  id         String  @id @default(cuid())
  sheetId    String
  fullName   String // expanded display name for this person
  normalized String // normalized form for soft matching
  isPrimary  Boolean @default(false) // the first / whole-cell name

  sheet RationingSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@index([normalized])
  @@index([sheetId])
}

enum RationingFollowKind {
  FOUND // customer found their name → wants updates about that land
  WATCH // customer didn't find it → notify (SMS) when it appears in a future sheet
}

/// A logged-in customer following the rationing ledger. Never implies ownership (#12).
/// FOUND links to the sheet row they recognised; WATCH is an alert/saved-search by name.
/// Designed to later graduate into a Module-2 LandFollow once concrete land details exist.
model RationingFollow {
  id             String              @id @default(cuid())
  userId         String
  kind           RationingFollowKind
  applicantName  String
  nameNorm       String // normalized — matched against new imports for WATCH alerts
  plotNo         String?
  blockNo        String?
  originalOwner  String?
  cityId         String?
  sheetId        String? // source row (FOUND) or the row that matched a WATCH
  status         String              @default("active") // active | matched | closed
  lastNotifiedAt DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  city  RationingCity?  @relation(fields: [cityId], references: [id], onDelete: SetNull)
  sheet RationingSheet? @relation("FollowSheet", fields: [sheetId], references: [id], onDelete: SetNull)

  @@index([nameNorm])
  @@index([userId])
  @@index([status, kind])
}

/// A scanned rationing-sheet page. Linked to applicant rows by file name == RationingSheet.sourceFile.
/// One scan typically covers many applicants (a whole page). Stored via the upload pipeline.
model RationingScan {
  id           String   @id @default(cuid())
  fileName     String   @unique // must equal RationingSheet.sourceFile (e.g. "1 06 2026 02.jpg")
  path         String // public URL, e.g. /uploads/2026/06/uuid.jpg
  mime         String
  width        Int?
  height       Int?
  attachmentId String?
  uploadedById String?
  createdAt    DateTime @default(now())

  uploadedBy User? @relation("ScanUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

/// An Excel import run — groups the rows it produced so staff can review/delete a batch.
model SheetImportBatch {
  id             String   @id @default(cuid())
  fileName       String
  rowCount       Int      @default(0) // applicant rows attached to this batch
  createdCount   Int      @default(0) // new rows inserted
  updatedCount   Int      @default(0) // existing rows updated (conflict=update)
  duplicateCount Int      @default(0) // duplicates skipped (conflict=skip)
  flaggedCount   Int      @default(0) // rows imported with a verification remark
  note           String?
  uploadedById   String?
  createdAt      DateTime @default(now())

  uploadedBy User?            @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  sheets     RationingSheet[]

  @@index([createdAt])
}

/// A customer's request to follow a found land OR be notified when their land appears.
model InquiryRequest {
  id               String        @id @default(cuid())
  kind             InquiryKind
  status           InquiryStatus @default(OPEN)
  ownerName        String
  company          String?
  originalPiece    String?
  originalLocation String?
  originalMember   String?
  phone            String
  note             String?       @db.Text
  userId           String?
  matchedSheetId   String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  matchedSheet RationingSheet? @relation(fields: [matchedSheetId], references: [id], onDelete: SetNull)

  @@index([status, kind])
  @@index([phone])
}

/// Every search performed against the sheets — stored for admin review ("List of Sheets Inquiries").
model SheetSearchLog {
  id             String   @id @default(cuid())
  query          String
  field          String   @default("all") // all | name | owner | plot | block
  resultsCount   Int      @default(0)
  matched        Boolean  @default(false)
  usedSuggestion Boolean  @default(false) // visitor clicked a "did you mean?" suggestion
  userId         String?
  phone          String?
  createdAt      DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([matched])
}

// ─────────────────── Module 2: Lands & community database ───────────────────

enum LandType {
  SHEETS // تقنين / كشف
  ALLOCATED // تخصيص
}

enum LandOwnerKind {
  BROKER
  OWNER
  PERSONAL // ours / not commercial
}

enum LandStatus {
  DRAFT // raw find by the sales team (internal)
  REFINED // redefined + standardized
  READY // ready to publish
  PUBLISHED // linked to a marketplace listing
  ARCHIVED
}

/// Top-level area of the city (الحي). Bilingual name.
model District {
  id        String   @id @default(cuid())
  key       String   @unique
  nameAr    String
  nameEn    String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  neighborhoods Neighborhood[]
  advantages    Advantage[]
  updates       GeoUpdate[]
  follows       LandFollow[]
  landOffers    LandOffer[]
  linksFrom     DistrictLink[] @relation("DistrictLinkFrom")
  linksTo       DistrictLink[] @relation("DistrictLinkTo")

  @@index([isActive, order])
}

/// A neighborhood / مجاورة within a district, carrying the doc's metadata.
model Neighborhood {
  id            String   @id @default(cuid())
  districtId    String
  nameAr        String
  nameEn        String
  hasBlocks     Boolean  @default(false)
  assortedAreas Boolean  @default(false) // "many different areas"
  areas         Json? // selected area presets, e.g. [209, 276, 350]
  buildingTypes Json? // ['home','building','villa']
  mainRoads     Json? // ['R2','R3','ring','ismailia',...]
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  district   District     @relation(fields: [districtId], references: [id], onDelete: Cascade)
  blocks     Block[]
  lands      Land[]
  advantages Advantage[]
  updates    GeoUpdate[]
  follows    LandFollow[]
  listings   Listing[]
  landOffers LandOffer[]
  amenities  Amenity[]
  linksFrom  NeighborhoodLink[] @relation("NeighborhoodLinkFrom")
  linksTo    NeighborhoodLink[] @relation("NeighborhoodLinkTo")

  @@index([districtId, order])
  @@index([isActive])
}

/// An optional block within a neighborhood (بلوك). Codes are language-neutral.
model Block {
  id             String   @id @default(cuid())
  neighborhoodId String
  name           String
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  neighborhood Neighborhood @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)
  lands        Land[]
  updates      GeoUpdate[]
  follows      LandFollow[]

  @@index([neighborhoodId, order])
}

/// A land / piece record (قطعة) with the internal find→refine→publish workflow.
model Land {
  id              String         @id @default(cuid())
  landType        LandType
  neighborhoodId  String? // allocated lands use the hierarchy
  blockId         String?
  pieceNo         String?
  sheetLocation   String? // for SHEETS: qadessia/amal/talaee
  area            Decimal?       @db.Decimal(10, 2) // m²
  allocationDate  DateTime?
  utilitiesStatus String?
  price           Decimal?       @db.Decimal(14, 2)
  ownerKind       LandOwnerKind?
  ownerId         String? // set when commercial (BROKER/OWNER)
  details         String?        @db.Text
  status          LandStatus     @default(DRAFT)
  createdById     String?
  listingId       String?        @unique // link to the published marketplace listing
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  neighborhood Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)
  block        Block?        @relation(fields: [blockId], references: [id], onDelete: SetNull)
  owner        Owner?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  createdBy    User?         @relation("LandCreator", fields: [createdById], references: [id], onDelete: SetNull)
  listing      Listing?      @relation("LandListing", fields: [listingId], references: [id], onDelete: SetNull)
  updates      GeoUpdate[]
  follows      LandFollow[]

  @@index([status])
  @@index([neighborhoodId])
  @@index([blockId])
  @@index([landType])
}

/// A dated update on any geographic level; inherited downward at query time. Photos via Attachment.
model GeoUpdate {
  id             String   @id @default(cuid())
  districtId     String?
  neighborhoodId String?
  blockId        String?
  landId         String?
  title          String?  @db.Text // headline of the update
  body           String   @db.Text // rich HTML details — kept as-is across locales
  happenedAt     DateTime @default(now())
  createdById    String?
  createdAt      DateTime @default(now())
  notifiedAt     DateTime? // set when followers have been SMS-notified

  district     District?     @relation(fields: [districtId], references: [id], onDelete: Cascade)
  neighborhood Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)
  block        Block?        @relation(fields: [blockId], references: [id], onDelete: Cascade)
  land         Land?         @relation(fields: [landId], references: [id], onDelete: Cascade)
  createdBy    User?         @relation("GeoUpdateAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([districtId, happenedAt])
  @@index([neighborhoodId, happenedAt])
  @@index([blockId, happenedAt])
  @@index([landId, happenedAt])
}

/// A bilingual advantage / selling point for a district or neighborhood.
model Advantage {
  id             String   @id @default(cuid())
  districtId     String?
  neighborhoodId String?
  textAr         String   @db.Text
  textEn         String?  @db.Text
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  district     District?     @relation(fields: [districtId], references: [id], onDelete: Cascade)
  neighborhood Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)

  @@index([districtId, order])
  @@index([neighborhoodId, order])
}

/// Location / masterplan map for a district or neighborhood. One clean original is
/// uploaded; the system bakes a per-brand stamped copy for each site.
model AreaMap {
  id           String   @id @default(cuid())
  level        String // 'district' | 'neighborhood'
  areaId       String
  kind         String // 'location' | 'masterplan'
  cleanPath    String   @db.Text
  alswareyPath String?  @db.Text
  newobourPath String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([level, areaId, kind])
  @@index([level, areaId])
}

/// Reciprocal district adjacency (both directions are written, so it's symmetric).
model DistrictLink {
  id     String @id @default(cuid())
  fromId String
  toId   String
  from   District @relation("DistrictLinkFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to     District @relation("DistrictLinkTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
  @@index([fromId])
}

/// Public-realm amenity type (Roads, Services, …) — admin-managed taxonomy.
model AmenityType {
  id        String   @id @default(cuid())
  titleAr   String
  titleEn   String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  amenities Amenity[]

  @@index([isActive, order])
}

/// A public-realm amenity attached to a neighborhood (photos via Attachment 'Amenity').
model Amenity {
  id             String   @id @default(cuid())
  neighborhoodId String
  typeId         String
  titleAr        String
  titleEn        String?
  detailsAr      String?  @db.Text
  detailsEn      String?  @db.Text
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  neighborhood Neighborhood @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)
  type         AmenityType  @relation(fields: [typeId], references: [id], onDelete: Restrict)

  @@index([neighborhoodId])
  @@index([typeId])
}

/// Reciprocal neighborhood adjacency.
model NeighborhoodLink {
  id     String @id @default(cuid())
  fromId String
  toId   String
  from   Neighborhood @relation("NeighborhoodLinkFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to     Neighborhood @relation("NeighborhoodLinkTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
  @@index([fromId])
}

/// A customer following a land / block / neighborhood / district for updates (free service).
model LandFollow {
  id             String   @id @default(cuid())
  userId         String?
  name           String?
  phone          String
  landId         String?
  blockId        String?
  neighborhoodId String?
  districtId     String?
  note           String?  @db.Text
  createdAt      DateTime @default(now())

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  land         Land?         @relation(fields: [landId], references: [id], onDelete: Cascade)
  block        Block?        @relation(fields: [blockId], references: [id], onDelete: Cascade)
  neighborhood Neighborhood? @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)
  district     District?     @relation(fields: [districtId], references: [id], onDelete: Cascade)

  @@index([phone])
  @@index([userId])
  @@index([landId])
  @@index([neighborhoodId])
}

// ─────────────────────── City services: News & Build Guide ───────────────────────

enum NewsCategory {
  FACILITIES // مرافق
  ROADS // طرق
  HANDOVERS // تسليمات
  REGULATIONS // لوائح وقوانين
  GENERAL // عام
}

/// Official city news posted by staff. Free text kept as entered; English optional.
/// Photos attach via Attachment (ownerType = 'News').
model News {
  id          String       @id @default(cuid())
  titleAr     String
  titleEn     String?
  bodyAr      String       @db.Text
  bodyEn      String?      @db.Text
  category    NewsCategory @default(GENERAL)
  pinned      Boolean      @default(false)
  publishedAt DateTime? // null = draft
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([publishedAt])
  @@index([category, publishedAt])
}

enum GuideSection {
  LICENSING // خطوات الترخيص
  HANDOVER // إجراءات الاستلام
  COMPANIES // شركات الترخيص والبناء
  COSTS // تكاليف البناء
}

/// Licensing & build guide entries, grouped by section and ordered.
model GuideEntry {
  id        String       @id @default(cuid())
  section   GuideSection
  titleAr   String
  titleEn   String?
  bodyAr    String       @db.Text
  bodyEn    String?      @db.Text
  order     Int          @default(0)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([section, order])
}
