{
  "name": "@noc/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "npm run generate",
    "generate": "dotenv -e ../../.env -- prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "seed": "dotenv -e ../../.env -- node prisma/seed.mjs",
    "seed:marketplace": "dotenv -e ../../.env -- node prisma/seed-marketplace.mjs",
    "seed:rationing": "dotenv -e ../../.env -- node prisma/seed-rationing.mjs",
    "seed:lands": "dotenv -e ../../.env -- node prisma/seed-lands.mjs",
    "seed:districts": "dotenv -e ../../.env -- node prisma/seed-districts.mjs",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "reset": "dotenv -e ../../.env -- prisma migrate reset",
    "typecheck": "tsc --noEmit",
    "seed:conditions": "dotenv -e ../../.env -- node prisma/seed-conditions.mjs",
    "seed:condition-images": "dotenv -e ../../.env -- node prisma/seed-condition-images.mjs",
    "sanitize:backfill": "dotenv -e ../../.env -- node prisma/sanitize-backfill.mjs"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.4",
    "prisma": "^6.1.0",
    "typescript": "^5.7.3"
  }
}
