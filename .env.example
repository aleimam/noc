# ─────────────────────────────────────────────────────────────
# NOC Platform — environment variables (example)
# Copy this file to `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────

# Database (MySQL). Create a `noc` database locally, then set this.
DATABASE_URL="mysql://root:@localhost:3306/noc"

# Auth.js — generate with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""

# SMS provider for customer OTP.
# "console" prints codes to the terminal (dev default; never sends paid SMS).
# Later options: "smsmisr" | "victorylink" | "twilio"
SMS_PROVIDER="console"

# Where uploaded media is stored (served at /uploads). Keep outside the build.
UPLOAD_DIR="./uploads"

# Bootstrap super-admin staff account, created by the seed script.
SUPERADMIN_EMAIL="admin@newobour.com"
SUPERADMIN_PASSWORD="changeme123"

# Public base URLs (links / CORS). Adjust per environment.
PORTAL_URL="http://localhost:3001"
BROKERAGE_URL="http://localhost:3002"
